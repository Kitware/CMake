{
  "$schema": "https://docs.oasis-open.org/sarif/sarif/v2.1.0/errata01/os/schemas/sarif-schema-2.1.0.json",
  "runs": [
    {
      "results": [
        {
          "level": "error",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "ProjectFatalError.cmake",
                  "uriBaseId": "PATH:<SOURCE_DIR>"
                },
                "region": {
                  "startLine": 1
                }
              }
            }
          ],
          "message": {
            "text": "Example error"
          },
          "ruleId": "CMake.FatalError",
          "ruleIndex": 0
        }
      ],
      "tool": {
        "driver": {
          "name": "CMake",
          "rules": [
            {
              "id": "CMake.FatalError",
              "name": "CMake Error"
            }
          ],
          "version": "<IGNORE>"
        }
      }
    }
  ],
  "version": "2.1.0"
}
