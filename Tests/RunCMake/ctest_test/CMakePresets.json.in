{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "my-configure-preset",
      "generator": "@RunCMake_GENERATOR@",
      "binaryDir": "${sourceDir}/build"
    }
  ],
  "testPresets": [
    {
      "name": "my-include-preset",
      "configurePreset": "my-configure-preset",
      "filter": {
        "include": {
          "name": "^test1$"
        }
      }
    },
    {
      "name": "my-exclude-preset",
      "configurePreset": "my-configure-preset",
      "filter": {
        "exclude": {
          "name": "^test3$"
        }
      }
    }
  ]
}
